{
  "contract_name": "ProofOfImpact",
  "address": "0xD931392177067735378b26e5EE37851284c19d69",
  "network": "testnetBradbury",
  "rpc": "https://rpc-bradbury.genlayer.com",
  "chain_id": 4221,
  "explorer": "https://explorer-bradbury.genlayer.com",
  "write_methods": [
    {
      "name": "create_task",
      "args": ["title: str", "description: str", "criteria: str", "reward_points: int"],
      "returns": "str (task_id)"
    },
    {
      "name": "submit_work",
      "args": ["task_id: str", "work_url: str", "description: str"],
      "returns": "str (sub_id)"
    },
    {
      "name": "evaluate_submission",
      "args": ["sub_id: str"],
      "returns": "str (JSON result)"
    }
  ],
  "view_methods": [
    { "name": "get_task", "args": ["task_id: str"], "returns": "str (JSON)" },
    { "name": "get_submission", "args": ["sub_id: str"], "returns": "str (JSON)" },
    { "name": "get_score", "args": ["sub_id: str"], "returns": "uint256" },
    { "name": "get_leaderboard_score", "args": ["address: str"], "returns": "uint256" },
    { "name": "get_task_count", "args": [], "returns": "uint256" },
    { "name": "get_submission_count", "args": [], "returns": "uint256" }
  ]
}
